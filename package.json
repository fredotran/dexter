    "@langchain/tavily": "^1.2.0",
    "@mariozechner/pi-tui": "^0.52.12",
    "@mozilla/readability": "^0.6.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.10.0",
    "croner": "^9.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.4.2",
